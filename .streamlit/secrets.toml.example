# Paste into Streamlit Cloud → App settings → Secrets
# https://share.streamlit.io — do NOT commit secrets.toml to git
#
# IMPORTANT: Put keys at the TOP LEVEL (no [aws] section required).
# After saving, click "Reboot app" in Streamlit settings (~1 min).

DEPLOY_ENV = "production"
DEPLOY_TARGET = "streamlit-cloud"

AWS_REGION = "us-east-1"
# Paste keys exactly — no extra spaces; must be a matching IAM key pair
AWS_ACCESS_KEY_ID = "AKIAxxxxxxxxxxxxxxxx"
AWS_SECRET_ACCESS_KEY = "your-secret-access-key"
# If InvalidSignatureException: create a NEW access key in IAM and replace BOTH lines
# Leave AWS_PROFILE unset on Cloud

# Resolves to us.anthropic.claude-haiku-4-5-20251001-v1:0 in us-east-1 automatically
BEDROCK_CHAT_MODEL_ID = "anthropic.claude-haiku-4-5-20251001-v1:0"
# Alternative: "amazon.nova-lite-v1:0"
BEDROCK_EMBEDDING_MODEL_ID = "amazon.titan-embed-text-v2:0"
BEDROCK_MAX_TOKENS = 1024
TITAN_EMBED_DIMENSIONS = 1024
VECTOR_DB_PATH = "data/vector_db"

# Optional news APIs
# FINNHUB_API_KEY = ""
# NEWSAPI_KEY = ""
