# Copy to .env for local / Docker Compose (never commit .env).

# --- AWS region ---
AWS_REGION=us-east-1
# Local: use `aws configure` and leave keys blank, OR set keys for Docker/cloud:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional named profile from ~/.aws/credentials (not used in most containers)
AWS_PROFILE=

# --- Amazon Bedrock ---
# Enable model access in AWS Console → Amazon Bedrock → Model access
# IAM: bedrock:InvokeModel on your chosen models
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
# Active model — copy inference profile id from Bedrock → Model catalog
BEDROCK_CHAT_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
# Alternatives: amazon.nova-lite-v1:0
# Legacy (do not use): claude-3-5-haiku-20241022, us.anthropic.claude-sonnet-4-6
BEDROCK_MAX_TOKENS=1024
# Titan embed dimensions: 256, 512, or 1024
TITAN_EMBED_DIMENSIONS=1024

# --- Local vector store (Phase 2) ---
VECTOR_DB_PATH=data/vector_db

# --- News (optional) ---
FINNHUB_API_KEY=
NEWSAPI_KEY=

# --- Server (Docker / production) ---
PORT=8501
DEPLOY_ENV=production
